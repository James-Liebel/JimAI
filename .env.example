# jimAI - Environment Configuration
# Copy this file to .env and adjust values as needed.
# Never commit a populated .env file.
# Required vars are marked [REQUIRED]. All others have sensible defaults.

# ── Model Runtime ────────────────────────────────────────────────────────────
# [REQUIRED] Ollama local endpoint
OLLAMA_BASE_URL=http://localhost:11434

# ── Backend Server ───────────────────────────────────────────────────────────
BACKEND_PORT=8000
LOG_LEVEL=INFO

# ── Data paths ───────────────────────────────────────────────────────────────
CHROMA_PATH=./chroma_db
KNOWLEDGE_GRAPH_PATH=./data/graph.json
STYLE_PROFILE_PATH=./data/style_profile.json

# ── Optional API authentication (for remote/Tailscale access) ───────────────
# Set PRIVATE_AI_AUTH_REQUIRED=true and provide a key to lock down the API.
PRIVATE_AI_API_KEY=
PRIVATE_AI_AUTH_REQUIRED=false

# ── Service URLs (free-stack / optional integrations) ────────────────────────
# These default to localhost — override for non-default ports or remote services.
N8N_BASE_URL=http://localhost:5678
QDRANT_BASE_URL=http://localhost:6333
SEARXNG_BASE_URL=http://localhost:18082
JUPYTER_BASE_URL=http://localhost:8888
GRAFANA_BASE_URL=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Limits how many autonomous run-start requests a single client IP can make.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RUN_MAX_CALLS=10
RATE_LIMIT_RUN_WINDOW_SECS=60

# ── CSRF Protection ───────────────────────────────────────────────────────────
# Checks for X-JimAI-CSRF: 1 header on state-changing requests.
# Set to false for Electron desktop app or API-only clients.
# The frontend sends this header automatically.
CSRF_ENABLED=true
